# ==================== 数据库 ====================
MYSQL_ROOT_PASSWORD=root

# ==================== 支付宝 (mall-portal) ====================
# 沙箱环境默认值，上线时替换为真实值
ALIPAY_APP_ID=
ALIPAY_PUBLIC_KEY=
ALIPAY_PRIVATE_KEY=
ALIPAY_RETURN_URL=http://你的域名/#/pages/money/paySuccess
ALIPAY_NOTIFY_URL=http://你的域名/api/alipay/notify

# ==================== 阿里云短信 (mall-portal) ====================
# 设为 true 启用真实短信，false 则只打印日志（开发模式）
ALIYUN_SMS_ENABLED=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
