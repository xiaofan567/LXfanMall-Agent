# ============ LLM Configuration ============
LLM_API_KEY=你的DeepSeek API Key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ============ Mall Backend (Docker 容器名) ============
MALL_PORTAL_URL=http://mall-portal:8085
MALL_SEARCH_URL=http://mall-search:8081
MALL_ADMIN_URL=http://mall-admin:8080
JWT_SECRET=mall-portal-secret
ADMIN_JWT_SECRET=mall-admin-secret
JWT_ALGORITHM=HS512

# ============ Application ============
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ============ Milvus ============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=LXfanmall_knowledge
MILVUS_DIMENSION=1024

# ============ RAG Redis Cache ============
RAG_REDIS_URL=redis://redis:6379/2
RAG_CACHE_TTL=86400
RAG_SIMILARITY_HIGH=0.95
RAG_SIMILARITY_MID=0.85

# ============ Embedding ============
EMBEDDING_API_KEY=你的DashScope API Key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# ============ Reranker ============
RERANKER_API_KEY=你的DashScope API Key
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANKER_MODEL=gte-rerank-v2

# ============ File Upload ============
UPLOAD_DIR=/app/uploads/rag_docs
MAX_UPLOAD_SIZE=20971520

# ============ Session & User Profile ============
SESSION_REDIS_URL=redis://redis:6379/3
SESSION_TTL=3600
SESSION_MAX_TURNS=20
