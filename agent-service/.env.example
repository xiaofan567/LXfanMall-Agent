# ============ LLM Configuration ============
LLM_API_KEY=your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ============ Mall Backend ============
MALL_PORTAL_URL=http://localhost:8085
MALL_SEARCH_URL=http://localhost:8081
JWT_SECRET=mall-portal-secret
ADMIN_JWT_SECRET=mall-admin-secret
JWT_ALGORITHM=HS512

# ============ Application ============
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ============ Milvus ============
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=mall_knowledge
MILVUS_DIMENSION=1024

# ============ RAG Redis Cache (db2) ============
RAG_REDIS_URL=redis://localhost:6379/2
RAG_CACHE_TTL=86400
RAG_SIMILARITY_HIGH=0.95
RAG_SIMILARITY_MID=0.85

# ============ Embedding (Qwen text-embedding-v4) ============
EMBEDDING_API_KEY=your-dashscope-api-key-here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# ============ Reranker (Qwen gte-rerank-v2) ============
RERANKER_API_KEY=
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANKER_MODEL=gte-rerank-v2

# ============ File Upload ============
UPLOAD_DIR=./uploads/rag_docs
MAX_UPLOAD_SIZE=20971520

# ============ Session & User Profile (Redis db3) ============
# 与 RAG 缓存(db2) 和 Java mall(db0) 隔离
SESSION_REDIS_URL=redis://localhost:6379/3
# 会话滑动过期时间（秒），用户停聊超过此时间后 session 自动清除
SESSION_TTL=3600
# 单个会话最大保留的对话轮数（每轮 = 用户消息 + AI 回复 = 2 条）
SESSION_MAX_TURNS=20
